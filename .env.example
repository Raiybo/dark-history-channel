# ── Gemini AI (free at aistudio.google.com) ────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud Text-to-Speech ─────────────────────────────────────────────────
# 1. Go to console.cloud.google.com
# 2. Create project → Enable "Cloud Text-to-Speech API"
# 3. IAM → Service Accounts → Create → Download JSON key
# 4. Paste the ENTIRE contents of the JSON key file here (as one line)
GOOGLE_TTS_CREDENTIALS={"type":"service_account","project_id":"..."}

# ── YouTube Data API v3 ─────────────────────────────────────────────────────────
# 1. Same Google Cloud project → Enable "YouTube Data API v3"
# 2. APIs & Credentials → OAuth 2.0 Client IDs → Desktop app
# 3. Run: npm run get-token  (one-time setup to get refresh token)
YOUTUBE_CLIENT_ID=your_client_id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your_client_secret
YOUTUBE_REFRESH_TOKEN=your_refresh_token

# ── Channel Branding ────────────────────────────────────────────────────────────
CHANNEL_NAME=Dark Chronicles
